JWT_SECRET_KEY=replace-with-a-long-random-string
JWT_EXPIRE_MINUTES=60

# development | production - controls uvicorn --reload vs gunicorn (see entrypoint.sh)
APP_ENV=development
GUNICORN_WORKERS=3
LOG_LEVEL=INFO

# Comma-separated list of origins allowed to call this API from a browser.
# Wildcard "*" is intentionally not supported here since it's not valid
# alongside allow_credentials=True per the CORS spec.
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

POSTGRES_DB=lms_db
POSTGRES_USER=lms_user
POSTGRES_PASSWORD=lms_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=replace-with-smtp-username
SMTP_PASSWORD=replace-with-smtp-app-password
DEFAULT_FROM_EMAIL=support@example.com
SMTP_USE_TLS=True
